                jQuery('#dndmedia_status').hide();
                 jQuery('#load_instrukcja1').hide();
                 jQuery('#load_instrukcja2').hide();
           
                jQuery("#browser-warning").fadeIn(125);
                
                jQuery('#old_choosefile').fadeIn(125);
                 
