            function initBrowserWarning() {
                var isChrome = navigator.userAgent.toLowerCase().indexOf('chrome') > -1;
                var isFirefox = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;
	
                if(!isChrome && !isFirefox){
